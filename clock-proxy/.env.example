# Porta do Clock Proxy (padrao: 4321)
PORT=4321

# Token Bearer para autenticacao com o Delirio Manager
# Gere um token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=

# Credenciais da interface web dos relogios Henry Hexa ADV
# Todas as unidades usam o mesmo usuario/senha (padrao de fabrica — trocar! LGPD Art. 46)
CLOCK_USER=teste fabrica
CLOCK_PASS=111111

# Caminho do Google Chrome instalado (nao usar o Chromium interno do Playwright)
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# IPs de todos os relogios Henry Hexa ADV — usados pelo endpoint /rh/offboard (bulk)
# Formato: lista separada por virgulas, sem espacos
CLOCK_IPS=192.168.15.151,192.168.14.151,192.168.12.151,192.168.0.151,192.168.13.151,192.168.18.151,192.168.16.151,192.168.20.151,192.168.10.150
